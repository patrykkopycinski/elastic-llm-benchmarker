{
  "$schema": "../src/types/config.ts",
  "ssh": {
    "host": "",
    "port": 22,
    "username": ""
  },
  "huggingfaceToken": "",
  "benchmarkThresholds": {
    "minContextWindow": 128000,
    "maxITLMs": 20,
    "maxToolCallLatencyMs": 1000,
    "minToolCallSuccessRate": 1.0,
    "concurrencyLevels": [1, 4, 16],
    "healthCheckTimeoutSeconds": 600
  },
  "vmHardwareProfile": {
    "gpuType": "nvidia-a100-sxm4-80gb",
    "gpuCount": 2,
    "ramGb": 340,
    "cpuCores": 24,
    "diskGb": 500,
    "machineType": "a2-ultragpu-2g"
  },
  "logLevel": "info",
  "resultsDir": "./results",
  "daemon": {
    "enabled": false,
    "sleepIntervalMs": 60000,
    "maxConsecutiveErrors": 10,
    "maxCycles": 0,
    "recursionLimit": 25,
    "stateFilePath": "./data/daemon-state.json",
    "pauseWindows": [],
    "errorBackoffMultiplier": 1.5,
    "maxSleepIntervalMs": 300000
  },
  "tunnel": {
    "enabled": false,
    "provider": "ngrok",
    "ngrokRegion": "us",
    "localPort": 8000,
    "timeoutMs": 30000,
    "retryAttempts": 3,
    "retryDelayMs": 5000
  },
  "kibanaConnector": {
    "enabled": false,
    "connectorNamePrefix": "vllm-",
    "requestTimeoutMs": 30000
  }
}
