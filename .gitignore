.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Test coverage
coverage/

# Logs
*.log
logs/

# Results (can be large)
results/

# Temporary files
tmp/
temp/
*.tmp

# Dashboard build output (committed source, not built artifacts)
dashboard/dist/

# Playwright
test-results/
playwright-report/

# Docker Compose
.env.docker

# LangGraph
.langgraph_api/
.worktrees/

# Additional Credentials
*.pem
*.key
id_rsa*

