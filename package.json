{
  "name": "elastic-llm-benchmarker",
  "version": "0.1.0",
  "description": "Automated LLM discovery, deployment, and benchmarking for Elastic Agent Builder qualification",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "elastic-llm-benchmarker": "dist/cli.js",
    "elbench": "dist/cli.js",
    "benchmarker-queue": "dist/cli.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "start": "node dist/index.js",
    "cli": "tsx src/cli.ts",
    "api": "tsx src/api/queue-server.ts",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"config/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"config/**/*.{ts,json}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "setup": "bash scripts/setup-local.sh && bash scripts/setup-ilm.sh",
    "validate:eis": "bash scripts/validate-eis.sh",
    "smoke:stage3": "bash scripts/smoke-stage3-e2e.sh",
    "smoke:full": "bash scripts/smoke-full-e2e.sh",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "infra:up": "docker compose --env-file .env.docker up -d elasticsearch kibana",
    "infra:down": "docker compose --env-file .env.docker down",
    "infra:reset": "docker compose --env-file .env.docker down -v",
    "infra:fleet": "docker compose --env-file .env.docker --profile fleet up -d"
  },
  "keywords": [
    "llm",
    "benchmark",
    "vllm",
    "elastic",
    "ai"
  ],
  "license": "MIT",
  "dependencies": {
    "@elastic/elasticsearch": "^8.17.0",
    "@huggingface/hub": "^2.11.0",
    "@octokit/rest": "^22.0.1",
    "async-mutex": "^0.5.0",
    "async-retry": "^1.3.3",
    "better-sqlite3": "^12.8.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "lru-cache": "^11.2.7",
    "opossum": "^9.0.0",
    "p-limit": "^7.3.0",
    "ssh2": "^1.16.0",
    "winston": "^3.17.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "ngrok": "^5.0.0-beta.2"
  },
  "devDependencies": {
    "@types/async-retry": "^1.4.9",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/opossum": "^8.1.9",
    "@types/ssh2": "^1.15.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.0",
    "supertest": "^7.2.2",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
