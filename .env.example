# SSH Configuration for GCP VM
SSH_HOST=your_vm_ip_address
SSH_PORT=22
SSH_USERNAME=your_ssh_user
SSH_PASSWORD=your_ssh_password_here
SSH_PRIVATE_KEY_PATH=

# HuggingFace API Token
HUGGINGFACE_TOKEN=hf_your_token_here_get_from_huggingface_settings

# Benchmark Thresholds (optional - defaults shown)
MIN_CONTEXT_WINDOW=128000
MAX_ITL_MS=20
MAX_TOOL_CALL_LATENCY_MS=1000
MIN_TOOL_CALL_SUCCESS_RATE=1.0
CONCURRENCY_LEVELS=1,4,16
HEALTH_CHECK_TIMEOUT_SECONDS=1200

# Hardware Profile (optional - use a predefined profile ID)
# Available profiles: 2xa100-80gb, 1xa100-80gb, 4xa100-80gb, 1xl4, 8xl4
# When set, profile hardware values are used as defaults.
# Individual VM_* settings below will override profile values.
HARDWARE_PROFILE_ID=2xa100-80gb

# VM Hardware Profile (optional - defaults shown)
# These can override values from HARDWARE_PROFILE_ID if both are set.
VM_GPU_TYPE=nvidia-a100-80gb
VM_GPU_COUNT=2
VM_RAM_GB=340
VM_CPU_CORES=24
VM_DISK_GB=1000
VM_MACHINE_TYPE=a2-ultragpu-2g

# Application Settings
LOG_LEVEL=info
RESULTS_DIR=./results

# Inference Engine Configuration (optional)
# Supported engines: 'vllm' (default, production-ready) or 'ollama' (simpler setup)
ENGINE_TYPE=vllm
# ENGINE_API_PORT=8000              # API port (vLLM default: 8000, Ollama default: 11434)
# ENGINE_DOCKER_IMAGE=              # Docker image override (default: vllm/vllm-openai:latest)
# ENGINE_MAX_MODEL_LEN=             # Maximum model length override

# Ollama-specific settings (only used when ENGINE_TYPE=ollama)
# OLLAMA_USE_DOCKER=false           # Use Docker for Ollama deployment
# OLLAMA_NUM_GPU_LAYERS=-1          # Number of GPU layers (-1 = all)

# vLLM-specific settings (only used when ENGINE_TYPE=vllm)
# VLLM_GPU_MEMORY_UTILIZATION=0.95  # GPU memory utilization fraction (maximize hardware usage)

# Tunnel Configuration (optional - for exposing inference API publicly)
# Set TUNNEL_ENABLED=true to expose vLLM via SSH forward + ngrok (required for CI smoke / Buildkite)
TUNNEL_ENABLED=true
TUNNEL_PROVIDER=ngrok
NGROK_AUTH_TOKEN=
NGROK_REGION=us
TUNNEL_LOCAL_PORT=18000
# NGROK_DOMAIN=          # Optional custom domain (requires ngrok paid plan)
# TUNNEL_TIMEOUT_MS=30000
# TUNNEL_RETRY_ATTEMPTS=3
# TUNNEL_RETRY_DELAY_MS=5000

# Kibana Connector Configuration (optional - for creating connectors to vLLM endpoint)
# Set KIBANA_CONNECTOR_ENABLED=true to auto-create Kibana connectors for evaluated models
KIBANA_CONNECTOR_ENABLED=false
KIBANA_CONNECTOR_URL=
KIBANA_CONNECTOR_API_KEY=
# KIBANA_CONNECTOR_NAME_PREFIX=vllm-
# KIBANA_CONNECTOR_REQUEST_TIMEOUT_MS=30000

# ─── Elasticsearch ──────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
# ELASTICSEARCH_API_KEY=
# ELASTICSEARCH_CLOUD_ID=

# ─── Elastic Agent ──────────────────────────────────────────────────────────
ELASTIC_AGENT_ENABLED=false
# ELASTIC_AGENT_FLEET_URL=
# ELASTIC_AGENT_ENROLLMENT_TOKEN=
# ELASTIC_AGENT_MODE=fleet

# ─── EIS (Elastic Inference Service) — Stage 3 Reasoning ────────────────────
# Serverless ES provisions EIS chat_completion endpoints natively — NO
# EIS_CCM_API_KEY is required there; the ELASTICSEARCH_API_KEY authorizes the
# inference stream directly. Set EIS_CCM_API_KEY only for self-managed/local ES
# that needs Cloud Connected Mode (CCM) activated.
# Preferred over LLM_API_KEY when set. Same key Kibana uses for `yarn es snapshot --eis`.
# Vault: vault read -field=key secret/kibana-issues/dev/inference/kibana-eis-ccm
# Alias: KIBANA_EIS_CCM_API_KEY (kbn convention) or EIS_CCM_API_KEY
# EIS_CCM_API_KEY=
# EIS_MODEL=eis/anthropic-claude-4.6-opus
# Self-managed/local ES must start with trial license + QA inference URL (scripts/setup-local.sh does this).
# DRA images: Snapshot → master via scripts/pull-dra-es-image.sh (ES_DRA_CHANNEL=snapshot)
# E2E smoke: npm run smoke:stage3
# Available models: eis/anthropic-claude-4.6-opus, eis/anthropic-claude-4.6-sonnet,
#   eis/google-gemini-3.1-pro, eis/google-gemini-3.0-flash,
#   eis/openai-gpt-5.4, eis/openai-gpt-oss-120b

# ─── LangGraph ──────────────────────────────────────────────────────────────
# LANGSMITH_API_KEY=

# Golden Cluster (centralized tracking)
ES_GOLDEN_CLOUD_ID=your-deployment-id
ES_GOLDEN_API_KEY=your-golden-api-key

# Stage 2 Thresholds
#STAGE2_MIN_ITL_P50_MS=20
#STAGE2_MIN_THROUGHPUT_TPS=10
#STAGE2_MAX_TTFT_MS=5000
#STAGE2_MIN_CONTEXT_WINDOW=128000

# Golden Cluster Config
#GOLDEN_CLUSTER_ENABLED=false
#GOLDEN_CLUSTER_URL=https://kbn-evals-serverless-ed035a.kb.us-central1.gcp.elastic.cloud
#GOLDEN_CLUSTER_API_KEY=
#GOLDEN_CLUSTER_FORWARD_TO_GOLDEN=false

# EDOT Collector Config
#EDOT_COLLECTOR_ENABLED=true
#EDOT_COLLECTOR_OTLP_ENDPOINT=http://localhost:4318
#EDOT_COLLECTOR_HEALTH_ENDPOINT=http://localhost:8080/healthz
#EDOT_COLLECTOR_TRACE_INDEX_PATTERN=traces-*
#EDOT_COLLECTOR_SAMPLING_RATE=1.0

# Kibana Repo Config
#KIBANA_REPO_URL=https://github.com/elastic/kibana.git
#KIBANA_REPO_PIN_TO_COMMIT=
#KIBANA_REPO_PIN_TO_TAG=
#KIBANA_REPO_CLONE_PATH=./.kibana-cache
#KIBANA_REPO_AUTO_PULL=true

# ─── Buildkite (required for CI eval pipeline) ───────────────────────────────
# BUILDKITE_API_TOKEN=          # or use ~/.buildkite/token via scripts/start-local.sh
BUILDKITE_KIBANA_BRANCH=fix/weekly-evals-matrix
# Comma-separated security matrix suites (on-demand only — no weekly pipeline)
BUILDKITE_DEFAULT_EVAL_SUITES=security-alert-triage,security-alerts-rag-regression,security-esql-generation-regression
BUILDKITE_DETACH_POLL=true
# Reuse in-flight Benchmarker build when model/connector/suite match (default true)
# BUILDKITE_ADOPT_RUNNING_BUILD=true
# Wait for other pipeline builds to finish before POSTing (default true)
# BUILDKITE_WAIT_FOR_PIPELINE_IDLE=true
