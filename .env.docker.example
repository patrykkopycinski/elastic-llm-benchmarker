# Copy to .env.docker and edit passwords
ELASTIC_PASSWORD=changeme
KIBANA_SYSTEM_PASSWORD=changeme

# Benchmarker app
BENCHMARKER_PORT=3100
LOG_LEVEL=info

# SSH connection to GPU VM (required for benchmark execution)
# SSH_HOST=your-gcp-vm-ip
# SSH_PORT=22
# SSH_USERNAME=your-username
# SSH_PASSWORD=your-password-or-leave-empty
# SSH_PRIVATE_KEY_PATH=~/.ssh/id_rsa

# HuggingFace token (required for vLLM model downloads)
# HUGGINGFACE_TOKEN=hf_xxx

# Optional overrides
# STACK_VERSION=8.17.0
# CLUSTER_NAME=benchmarker-local
# ES_PORT=9200
# KIBANA_PORT=5601
