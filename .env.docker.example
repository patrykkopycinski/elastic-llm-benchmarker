# Copy to .env.docker and edit passwords
ELASTIC_PASSWORD=changeme
KIBANA_SYSTEM_PASSWORD=changeme

# Benchmarker app
BENCHMARKER_PORT=3100
LOG_LEVEL=info

# SSH connection to GPU VM (required for benchmark execution)
# SSH_HOST=your-gcp-vm-ip
# SSH_PORT=22
# SSH_USERNAME=your-username
# SSH_PASSWORD=your-password-or-leave-empty
# SSH_PRIVATE_KEY_PATH=~/.ssh/id_rsa

# HuggingFace token (required for vLLM model downloads)
# HUGGINGFACE_TOKEN=hf_xxx

# Optional overrides
# DRA Elasticsearch — latest from Elastic Daily Releasable Artifacts
# Dashboard: https://artifacts-staging.elastic.co/dra-info/index.html
# Default: Snapshot tab → master (9.5.0-SNAPSHOT)
ES_DRA_CHANNEL=snapshot
ES_DRA_BRANCH=master
# ES_IMAGE is set by scripts/pull-dra-es-image.sh
# ES_IMAGE=benchmarker-elasticsearch:snapshot-master

# Staging tab alternative (released branches, e.g. 9.4.3):
# ES_DRA_CHANNEL=staging
# ES_DRA_BRANCH=9.4

# Stack version for Kibana / Elastic Agent services in docker-compose
# STACK_VERSION=9.5.0-SNAPSHOT
# CLUSTER_NAME=benchmarker-local
# ES_PORT=9223
# KIBANA_PORT=5601
